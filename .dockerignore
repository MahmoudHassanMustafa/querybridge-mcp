# Keep the build context small + secrets out of the image
node_modules
dist
coverage

# Local config — never bake credentials into the image
config.json
*.env
.env*

# VCS + CI
.git
.github
.gitignore

# Dev tooling
.changeset
.prettier*
eslint.config.js
vitest.config.ts
vitest.integration.config.ts

# Tests don't ship in production
src/__tests__

# Editor / OS noise
.vscode
.idea
.DS_Store
Thumbs.db

# Docs (image stays lean; users read these on GitHub)
README.md
CONTRIBUTING.md
SECURITY.md
CHANGELOG.md
LICENSE
