{
  "name": "querybridge-mcp",
  "version": "0.4.1",
  "description": "MCP server connecting Claude Code with MySQL — supports SSH tunnels and multiple databases",
  "license": "MIT",
  "author": "Mahmoud Hassan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MahmoudHassanMustafa/querybridge-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/MahmoudHassanMustafa/querybridge-mcp/issues"
  },
  "homepage": "https://github.com/MahmoudHassanMustafa/querybridge-mcp#readme",
  "keywords": [
    "mcp",
    "mysql",
    "claude",
    "claude-code",
    "model-context-protocol",
    "ssh-tunnel",
    "database"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "querybridge-mcp": "dist/cli.js",
    "querybridge-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "pnpm test && pnpm test:integration",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "prepublishOnly": "pnpm lint && pnpm build && pnpm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "mysql2": "^3.14.1",
    "ssh2": "^1.16.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@testcontainers/mysql": "^12.0.0",
    "@types/node": "^22.15.3",
    "@types/ssh2": "^1.15.4",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cpu-features",
      "ssh2"
    ]
  }
}
